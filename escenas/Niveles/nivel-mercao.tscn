text = "@export var vendedores: List[CharacterBody2D]

@export var puestos: List[Sprite2D]

var dineroPrevioPorVendedor: float = 50;

activarElementos(vendedores, puestos, dineroPrevioPorVendedor);

func activarElementos(*,*,*):
     for vendedor in vendedores:
          vendedor.show();
          vendedor.dineroPrevio = dineroPrevioPorVendedor;
     for puesto in puestos:
          puesto.show();"

