config_version=5

[application]

config/name="Godot Fight"
run/main_scene="uid://b5iedpw7s5iny"
config/features=PackedStringArray("4.5", "GL Compatibility")

[autoload]

Cargador="*res://escenas/Menus/MenuCarga/Cargador.gd"
Global="*res://escenas/MapaAldeaEsmeralda/Global.gd"
Database="*res://database/Database.gd"

[display]

window/size/initial_position_type=0
window/size/borderless=true
window/stretch/mode="canvas_items"
mouse_cursor/custom_image="uid://deg8qmcmwv7bx"

[file_customization]

